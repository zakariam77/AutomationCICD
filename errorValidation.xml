<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="saucedemoTests" parallel="methods" thread-count="4">
    <groups>
        <run>
            <include name="failLogin"/>
        </run>
    </groups>
    <listeners>
        <listener class-name="Listeners.Listener"/>
        <listener class-name="Listeners.TransformerListener"/>
    </listeners>
    <test name = "submitOrder">
        <classes>
            <class name="tests.submitOrder"/>
        </classes>
    </test>

</suite>